# MongoDB
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/?appName=CareSight

# AI / Voice
GEMINI_API_KEY=your_key_here
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Viam (hardware)
VIAM_API_KEY=your_key_here
VIAM_API_KEY_ID=your_key_id_here
VIAM_ADDRESS=your-robot-main.xxxxx.viam.cloud

# Alerts (optional)
HEX_API_KEY=your_key_here
NANOCLAW_API_KEY=your_key_here

# Defaults
DEFAULT_EXPECTED_COLOR=red
